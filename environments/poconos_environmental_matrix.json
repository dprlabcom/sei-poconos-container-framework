{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DPRLAB_SEI_Poconos_Environmental_Matrix",
  "description": "Public Repository Demo: Multi-seasonal environmental state machine mapping atmospheric scattering variables, seasonal vegetation states, and material micro-roughness behaviors for Project #3.",
  "global_biome_settings": {
    "location_profile": "pocono_mountains_montane",
    "dominant_canopy": {
      "pinus_strobus_evergreen": 0.60,
      "acer_rubrum_deciduous": 0.40
    }
  },
  "environmental_permutations": {
    "variation_01_autumnal_canopy": {
      "season_label": "Autumn Peak",
      "ground_cover": "saturated_soil_with_high_density_deciduous_leaf_litter",
      "solar_position": {
        "altitude_deg": 18.5,
        "azimuth_deg": 235.0,
        "intensity_lux": 72000
      },
      "atmospheric_scattering": {
        "rayleigh_factor": 0.85,
        "mie_factor": 0.38,
        "air_particulate_profile": "low_altitude_river_valley_mist",
        "chromatic_shift_target": "#E67E22"
      },
      "material_surface_modifiers": {
        "taupe_cladding_specular": 0.12,
        "cedar_soffit_saturation_multiplier": 1.15,
        "glazing_index_of_refraction": 1.52,
        "interior_luminescence": {
          "enabled": true,
          "color_temperature_k": 3000,
          "flux_lumens": 3500
        }
      }
    },
    "variation_02_winter_alpine": {
      "season_label": "Winter Twilight / Blue Hour",
      "ground_cover": "uniform_fresh_snow_pack_high_albedo",
      "solar_position": {
        "altitude_deg": -6.0,
        "azimuth_deg": 242.0,
        "intensity_lux": 250
      },
      "atmospheric_scattering": {
        "rayleigh_factor": 0.98,
        "mie_factor": 0.15,
        "air_particulate_profile": "sub_zero_crystalline_frost_haze",
        "chromatic_shift_target": "#2C3E50"
      },
      "material_surface_modifiers": {
        "taupe_cladding_specular": 0.05,
        "dark_walnut_soffit_roughness": 0.82,
        "glazing_index_of_refraction": 1.54,
        "accumulation_vectors": {
          "structural_roof_snow_depth_m": 0.15,
          "retaining_wall_frost_accumulation": true
        },
        "interior_luminescence": {
          "enabled": true,
          "color_temperature_k": 2400,
          "flux_lumens": 4800
        },
        "exterior_uplighting": {
          "enabled": true,
          "target_nodes": ["charcoal_steel_columns", "cantilever_underside"],
          "color_temperature_k": 4000
        }
      }
    }
  }
}
